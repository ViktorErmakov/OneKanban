<!doctype html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>OneKanban</title><script defer="defer">(()=>{"use strict";var e={56:(e,n,t)=>{e.exports=function(e){var n=t.nc;n&&e.setAttribute("nonce",n)}},72:e=>{var n=[];function t(e){for(var t=-1,r=0;r<n.length;r++)if(n[r].identifier===e){t=r;break}return t}function r(e,r){for(var a={},i=[],c=0;c<e.length;c++){var s=e[c],l=r.base?s[0]+r.base:s[0],d=a[l]||0,p="".concat(l," ").concat(d);a[l]=d+1;var u=t(p),g={css:s[1],media:s[2],sourceMap:s[3],supports:s[4],layer:s[5]};if(-1!==u)n[u].references++,n[u].updater(g);else{var m=o(g,r);r.byIndex=c,n.splice(c,0,{identifier:p,updater:m,references:1})}i.push(p)}return i}function o(e,n){var t=n.domAPI(n);return t.update(e),function(n){if(n){if(n.css===e.css&&n.media===e.media&&n.sourceMap===e.sourceMap&&n.supports===e.supports&&n.layer===e.layer)return;t.update(e=n)}else t.remove()}}e.exports=function(e,o){var a=r(e=e||[],o=o||{});return function(e){e=e||[];for(var i=0;i<a.length;i++){var c=t(a[i]);n[c].references--}for(var s=r(e,o),l=0;l<a.length;l++){var d=t(a[l]);0===n[d].references&&(n[d].updater(),n.splice(d,1))}a=s}}},113:e=>{e.exports=function(e,n){if(n.styleSheet)n.styleSheet.cssText=e;else{for(;n.firstChild;)n.removeChild(n.firstChild);n.appendChild(document.createTextNode(e))}}},208:(e,n,t)=>{t.d(n,{A:()=>m});var r=t(601),o=t.n(r),a=t(314),i=t.n(a),c=t(417),s=t.n(c),l=new URL(t(387),t.b),d=new URL(t(542),t.b),p=i()(o()),u=s()(l),g=s()(d);p.push([e.id,`:root {\n    --bg-primary: #ffffff;\n    --bg-secondary: rgb(247, 246, 246);\n    --br-block: rgb(247, 246, 246);\n    --bg-tertiary: aliceblue;\n    --text-primary: #333333;\n    --text-secondary: rgb(121, 121, 121);\n    --text-tertiary: rgb(80, 80, 80);\n    --border-color: #ebebeb;\n    --card-bg: #2a2a2a;\n    --card-border: #ebebeb;\n    --card-shadow: rgba(0, 0, 0.05);\n    --card-hover: lightgrey;\n    --card-hover-shadow: 0 0 8px rgba(100, 100, 100, 0.5);\n    --tag-bg: lightgrey;\n    --tag-inactive-bg: rgb(233, 233, 233);\n    --tag-text: #333333;\n    --link-color: rgb(17, 138, 236);\n    --link-hover: rgb(17, 138, 236);\n    --command-bg: white;\n    --icon-color: #8c8c8c;\n    --icon-hover: #8c8c8c;\n    --button-bg: #f0f0f0;\n    --button-active-bg: #8c8c8c;\n    --button-text: rgb(17, 138, 236);\n    --dragover-bg: #e6f7ff;\n    --dragover-border: #91d5ff;\n    --header-hover: aliceblue;\n    --header-shadow: rgba(0, 0, 0, 0.1);\n    --add-task-bg: transparent;\n    --add-task-hover: #8c8c8c;\n}\n\n/* подключаем внешний шрифт */\n/*@import url("https://fonts.googleapis.com/css2?family=Inter&display=swap");*/\n\nhtml {\n    font-size: 62.5%;\n    box-sizing: border-box;\n}\n\n*, *::before, *::after {\n    box-sizing: inherit;\n}\n\nbody {\n    margin: 0;\n    font-size: 1.7rem;\n    overflow: auto;\n    height: 100vh;\n    background-color: var(--bg-primary);\n    color: var(--text-primary);\n    transition: background-color 0.3s ease, color 0.3s ease;\n}\n\n.scrollable-container::-webkit-scrollbar {\n    width: 0;\n}\n\n.wrapper {\n    color: var(--text-primary);\n    font-family: "Inter", sans-serif;\n    display: flex;\n    flex-direction: column;\n    background-color: var(--bg-primary);\n    min-height: 100vh;\n}\n\n.wrapper.dark-theme {\n    --bg-primary: #1a1a1a;\n    --bg-secondary: #242424;\n    --br-block: #1a1a1a;\n    --bg-tertiary: #333333;\n    --text-primary: #e0e0e0;\n    --text-secondary: #9a9a9a;\n    --text-tertiary: #a0a0a0;\n    --border-color: #3a3a3a;\n    --card-bg: #ffffff;\n    --card-border: #3a3a3a;\n    --card-shadow: rgba(0, 0, 0, 0.3);\n    --card-hover: #494949;\n    --card-hover-shadow: 0 0 12px rgba(90, 10, 180, 0.4), 0 0 20px rgba(70, 80, 160, 0.3);\n    --tag-bg: #4a4a4a;\n    --tag-inactive-bg: #383838;\n    --tag-text: #b0b0b0;\n    --link-color: #6fa8d8;\n    --link-hover: #8ab8e8;\n    --command-bg: #242424;\n    --icon-color: #8a8a8a;\n    --icon-hover: #b0b0b0;\n    --button-bg: #2a2a2a;\n    --button-active-bg: #5a6a7a;\n    --button-text: #6fa8d8;\n    --dragover-bg: #2f3d4d;\n    --dragover-border: #4a6a8a;\n    --header-hover: #333333;\n    --header-shadow: rgba(0, 0, 0, 0.3);\n    --add-task-bg: #3a3a3a;\n    --add-task-hover: #5a6a7a;\n}\n\n.sticky_blok {\n    display: flex;\n    position: fixed;\n    top: 0;\n    flex-direction: column;\n    z-index: 100;\n    width: 100%;\n    background-color: var(--command-bg);\n    transition: background-color 0.3s ease;\n}\n\n#kanban-board {\n    display: flex;\n    width: 100%;\n    flex: 1;\n}\n\n/* Плейсхолдер "Выберите проект" в project_picker */\n.project_picker_placeholder {\n    color: var(--text-secondary);\n    font-style: italic;\n    font-size: 1.4rem;\n    padding: 0.4rem 0.8rem;\n    white-space: nowrap;\n}\n\n/* Состояние когда нет выбранных проектов */\n.project_picker.no-selection {\n    border-color: var(--border-color);\n}\n\n#kanban_header {\n    display: flex;\n    width: 100%;\n    min-height: 5.8rem;\n    background-color: var(--bg-primary);\n}\n\n#main-content-wrapper {\n    /* Чтобы масштабирование происходило из верхнего левого угла, а не из центра */\n    transform-origin: top left;\n    /* Добавьте transition для плавности масштабирования */\n    /* transition: transform 0.2s ease-in-out;  */\n}\n\n.block_header {\n    display: flex;\n    align-items: center;\n    border-top-left-radius: 1rem;\n    border-top-right-radius: 1rem;\n    border-top: var(--br-block) 1px solid;\n    background-color: var(--bg-secondary);\n    transition: background-color 0.3s ease;\n}\n\n.block_header:first-child {\n    margin-left: .5rem;\n}\n\n.kanban_body {\n    display: flex;\n    width: 100%;\n    min-height: calc(100vh - 11.8rem);\n}\n\n.kanban-block {\n    margin-top: 1.5rem;\n    background-color: var(--bg-secondary);\n    transition: background-color 0.3s ease;\n    display: flex;\n    flex-direction: column;\n    min-height: calc(100vh - 11.8rem);\n}\n\n.block_header,\n.kanban-block {\n    /* Для равномерного распределения колонок: */\n    flex: 1 1 0;\n    /* Позволяет элементам расти и занимать доступное пространство */\n    min-width: 0;\n    /* Важно для flex: 1, чтобы избежать переполнения */\n\n    padding: 0.6rem;\n    margin-right: .5rem;\n    /* box-sizing: border-box; */\n}\n\n.kanban-block:first-child {\n    margin-left: .5rem;\n}\n\n.kanban-block:hover {\n    background-color: var(--bg-tertiary);\n}\n\n/* Пример стилей для подсветки */\n.block_header--hovered {\n    background-color: var(--header-hover);\n    /* Более светлый фон */\n    box-shadow: 0 2px 5px var(--header-shadow);\n    /* Небольшая тень */\n    transition: background-color 0.2s ease, box-shadow 0.2s ease;\n    /* Плавный переход */\n}\n\n/* Тёмная тема — project_pill и project_grid_item с заданным цветом проекта */\n.wrapper.dark-theme .project_pill[style*="--project-color"],\n.wrapper.dark-theme .project_grid_item[style*="--project-color"] {\n    background-color: var(--project-color);\n    border-color: transparent;\n    color: var(--text-primary);\n}\n\n.wrapper.dark-theme .project_pill[style*="--project-color"]:hover,\n.wrapper.dark-theme .project_grid_item[style*="--project-color"]:hover {\n    filter: brightness(0.85);\n}\n\n/* Тёмная тема — выбранный проект с цветом: затемнение */\n.wrapper.dark-theme .project_grid_item.selected[style*="--project-color"] {\n    filter: brightness(0.75);\n}\n\n.wrapper.dark-theme .project_grid_item.selected[style*="--project-color"]:hover {\n    filter: brightness(0.85);\n}\n\n/* Тёмная тема — project_pill и project_grid_item БЕЗ цвета (стили как у grouping_toggle) */\n.wrapper.dark-theme .project_pill:not([style*="--project-color"]),\n.wrapper.dark-theme .project_grid_item:not([style*="--project-color"]) {\n    background-color: var(--button-bg);\n    border: 1px solid var(--border-color);\n    color: var(--text-primary);\n}\n\n.wrapper.dark-theme .project_pill:not([style*="--project-color"]):hover,\n.wrapper.dark-theme .project_grid_item:not([style*="--project-color"]):hover {\n    background-color: var(--bg-tertiary);\n    border-color: var(--border-color);\n}\n\n/* Тёмная тема — выбранный проект без цвета: активный фон */\n.wrapper.dark-theme .project_grid_item.selected:not([style*="--project-color"]) {\n    background-color: var(--button-active-bg);\n    color: #e0e0e0;\n    border-color: var(--button-active-bg);\n}\n\n.wrapper.dark-theme .project_grid_item.selected:not([style*="--project-color"]):hover {\n    filter: brightness(1.1);\n}\n\n/* Светлая тема — выбранный проект без цвета: затемнение фона */\n.project_grid_item.selected:not([style*="--project-color"]) {\n    filter: brightness(0.85);\n}\n\n/* Цветная точка проекта в карточке */\n.tag_task {\n    width: 1rem;\n    height: 1rem;\n    border-radius: 50%;\n    background-color: var(--project-color, transparent);\n    flex-shrink: 0;\n    cursor: pointer;\n    transition: transform 0.15s ease;\n}\n\n.tag_task:hover {\n    transform: scale(1.4);\n}\n\n/* Иконка срочности (рядом с кружком проекта, визуально отдельно) */\n.card__urgency-wrap {\n    display: flex;\n    align-items: center;\n    flex-shrink: 0;\n    margin-left: 0.4rem;\n    cursor: pointer;\n    transition: transform 0.15s ease;\n}\n\n.card__urgency-wrap:hover {\n    transform: scale(1.3);\n}\n\n.card__urgency {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 1.6rem;\n    height: 1.6rem;\n    color: var(--urgency-color, #c62828);\n}\n\n.card__urgency .urgency-icon-svg {\n    width: 1.4rem;\n    height: 1.4rem;\n    fill: currentColor;\n}\n\n/* Иконка типа «ошибка» (жук) */\n.card__bug-icon {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 1.6rem;\n    height: 1.6rem;\n    color: #c62828;\n    flex-shrink: 0;\n    margin-left: 0.2rem;\n    cursor: pointer;\n    transition: transform 0.15s ease;\n}\n\n.card__bug-icon:hover {\n    transform: scale(1.3);\n}\n\n.card__bug-icon .cardtype-icon-svg {\n    width: 1.4rem;\n    height: 1.4rem;\n    fill: currentColor;\n}\n\n/* ========== PROJECT PICKER (Tag-picker с dropdown) ========== */\n.project_picker {\n    position: relative;\n    display: inline-flex;\n    align-items: center;\n    background-color: var(--bg-tertiary);\n    padding: 0.3rem 0.5rem;\n    border-radius: 1.6rem;\n    margin-right: 1rem;\n}\n\n/* Выбранные проекты (pills в ряд) */\n.project_picker_selected {\n    display: flex;\n    flex-wrap: nowrap;\n    align-items: center;\n    overflow: hidden;\n}\n\n/* Pill выбранного проекта */\n/* Светлая тема: если есть цвет проекта — используем его, иначе стандартный фон */\n.project_pill {\n    display: flex;\n    align-items: center;\n    padding: 0.3rem 0.7rem;\n    margin: 0.15rem;\n    background-color: var(--project-color, var(--button-bg));\n    border: 1px solid var(--border-color);\n    border-radius: 1.6rem;\n    font-size: 1.4rem;\n    color: var(--text-primary);\n    white-space: nowrap;\n    cursor: pointer;\n    position: relative;\n    transition: opacity 0.2s ease, filter 0.2s ease, background-color 0.3s ease, border-color 0.3s ease;\n    -webkit-user-select: none;\n    user-select: none;\n}\n\n/* Светлая тема: проекты с цветом — прозрачная граница */\n.project_pill[style*="--project-color"] {\n    border-color: transparent;\n}\n\n/* Кнопка × */\n.project_pill_close {\n    margin-left: 0.5rem;\n    font-size: 1.6rem;\n    opacity: 0.6;\n    transition: opacity 0.2s ease;\n    line-height: 1;\n}\n\n.project_pill:hover .project_pill_close {\n    opacity: 1;\n}\n\n/* Светлая тема: hover для проектов с цветом */\n.project_pill[style*="--project-color"]:hover {\n    filter: brightness(0.9);\n}\n\n/* Светлая тема: hover для проектов без цвета */\n.project_pill:not([style*="--project-color"]):hover {\n    background-color: var(--bg-tertiary);\n}\n\n/* Кнопка открытия dropdown */\n.project_picker_toggle {\n    display: flex;\n    align-items: center;\n    padding: 0.4rem 0.8rem;\n    margin-left: 0.3rem;\n    background-color: var(--button-bg);\n    border: 1px solid var(--border-color);\n    border-radius: 1.6rem;\n    cursor: pointer;\n    font-size: 1.5rem;\n    color: var(--text-primary);\n    transition: background-color 0.2s ease;\n    -webkit-user-select: none;\n    user-select: none;\n}\n\n.project_picker_toggle:hover {\n    background-color: var(--bg-tertiary);\n}\n\n.project_picker_toggle .dropdown_arrow {\n    stroke: var(--text-secondary);\n    transition: transform 0.2s ease;\n}\n\n.project_picker.open .project_picker_toggle .dropdown_arrow {\n    transform: rotate(180deg);\n}\n\n/* Счётчик "+N" */\n.project_picker_more {\n    margin-right: 0.4rem;\n    font-weight: 500;\n}\n\n.project_picker_more:empty {\n    display: none;\n}\n\n.project_picker_more:empty + .dropdown_arrow {\n    margin-left: 0;\n}\n\n/* Dropdown с сеткой проектов */\n.project_picker_dropdown {\n    position: absolute;\n    top: calc(100% + 0.4rem);\n    left: 0;\n    min-width: 30rem;\n    max-width: 50rem;\n    background-color: var(--command-bg);\n    border: 1px solid var(--border-color);\n    border-radius: 0.8rem;\n    box-shadow: 0 4px 12px var(--card-shadow);\n    opacity: 0;\n    visibility: hidden;\n    transform: translateY(-0.5rem);\n    transition: all 0.2s ease;\n    z-index: 200;\n    padding: 0.8rem;\n}\n\n.project_picker.open .project_picker_dropdown {\n    opacity: 1;\n    visibility: visible;\n    transform: translateY(0);\n}\n\n/* Сетка проектов (2-3 колонки) */\n.project_picker_grid {\n    display: flex;\n    flex-wrap: wrap;\n}\n\n/* Элемент в сетке — заливка цветом проекта */\n.project_grid_item {\n    display: flex;\n    align-items: center;\n    padding: 0.5rem 2.5rem 0.5rem 1rem;\n    margin: 0.3rem;\n    background-color: var(--project-color, var(--button-bg));\n    border: 1px solid transparent;\n    border-radius: 1.6rem;\n    font-size: 1.5rem;\n    color: var(--text-primary);\n    cursor: pointer;\n    position: relative;\n    transition: filter 0.2s ease;\n    -webkit-user-select: none;\n    user-select: none;\n}\n\n.project_grid_item:hover {\n    filter: brightness(0.92);\n}\n\n/* Выбранный проект в сетке — без изменения цвета */\n/* .project_grid_item.selected — наследует цвет */\n\n.project_grid_item.selected:hover {\n    filter: brightness(0.95);\n}\n\n/* Галочка для выбранного проекта */\n.project_grid_item.selected::after {\n    content: "✓";\n    position: absolute;\n    right: 0.8rem;\n    font-size: 1.2rem;\n}\n\n/* Разделитель перед «Выбрать все» */\n.project_grid_separator {\n    flex-basis: 100%;\n    height: 0;\n    border-top: 1px solid var(--border-color);\n    margin: 0.4rem 0.3rem 0;\n}\n\n/* Псевдо-проект «Выбрать все» */\n.project_grid_item_all {\n    flex-basis: 100%;\n    background-color: transparent !important;\n    border: 1px dashed var(--border-color) !important;\n    font-style: italic;\n    color: var(--text-secondary);\n}\n\n.project_grid_item_all:hover {\n    background-color: var(--bg-tertiary) !important;\n    filter: none;\n}\n\n.wrapper.dark-theme .project_grid_item_all {\n    background-color: transparent !important;\n    border-color: var(--border-color) !important;\n}\n\n.wrapper.dark-theme .project_grid_item_all:hover {\n    background-color: var(--bg-tertiary) !important;\n    filter: none;\n}\n\n/* чекбоксы */\n\n/* КАРТОЧКИ */\n/* настройки карточки */\n.card {\n    /* цвет фона */\n    /* background-color: var(--card-bg); */\n    /* граница */\n    border: 1px solid var(--card-border);\n    /* рисуем границу по периметру карточки */\n    /* межстрочное расстояние */\n    line-height: 1.5;\n    /* радиус скругления */\n    border-radius: .8rem;\n    /* рисуем тень */\n    /* box-shadow: var(--card-shadow) 0px 1px 4px; */\n    /* скрываем всё, что не помещается в блок */\n    /* overflow: hidden; */\n    /* включаем гибкую вёрстку */\n    display: flex;\n    /* организуем вёрстку по столбцам */\n    flex-direction: column;\n    /* выравниваем карточки по центру друг относительно друга */\n    justify-content: space-between;\n    align-items: center;\n    margin-top: 1rem;\n    padding: .5rem;\n    color: var(--text-primary);\n\n    /* Обеспечиваем плавный переход для opacity и height */\n    transition: opacity 0.5s ease-out, height 0.5s ease-out, background-color 0.3s ease, border-color 0.3s ease;\n    /* Время и тип анимации */\n    overflow: hidden;\n    /* Важно! Скрывает контент, когда высота уменьшается */\n\n}\n\n/* меняем цвет рамки карточки при наведении */\n.card:hover {\n    background-color: var(--card-hover);\n    box-shadow: var(--card-shadow) 0px 1px 4px, var(--card-hover-shadow);\n}\n\n/* если тег не отмечен */\n.card__inactive {\n    opacity: 0;\n    /* Делаем невидимым */\n    height: 0;\n    /* Устанавливаем высоту в 0, чтобы элемент не занимал место */\n    padding-top: 0;\n    padding-bottom: 0;\n    margin-top: 0;\n    margin-bottom: 0;\n    border-width: 0;\n}\n\n/* КАРТОЧКИ */\nlabel {\n    cursor: pointer;\n    color: var(--text-primary);\n    transition: color 0.3s ease;\n}\n\n.kanban-block__name {\n    margin-left: 1rem;\n    color: var(--text-secondary);\n}\n\n.kanban-block__number {\n    margin-left: 1rem;\n    color: var(--text-tertiary);\n}\n\n.card__header {\n    display: flex;\n    width: 100%;\n    justify-content: space-between;\n    align-items: start;\n}\n\n.card__link {\n    color: var(--link-color);\n    text-decoration: none;\n    transition: color 0.3s ease;\n}\n\n.card__link:hover {\n    text-decoration: underline;\n    color: var(--link-hover);\n}\n\n.card__photo {\n    width: 3.5rem;\n    height: 4rem;\n    border: 1px solid var(--border-color);\n    background-color: var(--bg-secondary);\n    transition: background-color 0.3s ease;\n    cursor: pointer;\n}\n\n.card__photo:hover {\n    background-color: var(--bg-tertiary);\n    transform: scale(1.4);\n    position: relative;\n    right: 1rem;\n    top: 1rem;\n}\n\n.card__text {\n    display: flex;\n    width: 100%;\n    color: var(--text-primary);\n}\n\n.command_panel {\n    display: flex;\n    flex-direction: row;\n    align-items: center;\n    padding: .5rem;\n    background-color: var(--command-bg);\n    justify-content: space-between;\n    min-height: 6rem;\n    /* border-bottom: 1px solid var(--border-color); */\n    transition: background-color 0.3s ease, border-color 0.3s ease;\n}\n\n.command_panel_buttons {\n    display: flex;\n    flex-direction: row;\n    align-items: center;\n    justify-content: flex-end;\n    margin-left: auto;\n}\n\n.command_panel_buttons>* {\n    margin-right: 1rem;\n}\n\n.command_panel_buttons>*:last-child {\n    margin-right: 0;\n}\n\n#update_svg,\n#setup_svg {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    width: 3rem;\n    height: 3rem;\n    transition: transform 0.4s ease;\n    cursor: pointer;\n}\n\n#update_svg svg,\n#setup_svg svg {\n    fill: var(--icon-color);\n    stroke: var(--icon-color);\n    transition: fill 0.3s ease, stroke 0.3s ease;\n}\n\n/*Вращаем кнопку обновления на 180 градусов*/\n#update_svg:hover,\n#setup_svg:hover {\n    transform: rotate(180deg);\n}\n\n#update_svg:hover svg,\n#setup_svg:hover svg {\n    fill: var(--icon-hover);\n    stroke: var(--icon-hover);\n}\n\n/*Убираем вращение и увеличиваем кнопку*/\n#update_svg:active,\n#setup_svg:active {\n    transform: rotate(-180deg) scale(1.2);\n}\n\n.my_tasks {\n    color: var(--text-primary);\n    text-decoration: none;\n    font-family: 'Arial', sans-serif;\n    padding: 0.4rem 1rem;\n    border-radius: 1.6rem;\n    transition: all 0.3s ease;\n    display: inline-block;\n    border: 1px solid var(--border-color);\n    cursor: pointer;\n    -webkit-user-select: none;\n    user-select: none;\n    background-color: var(--button-bg);\n    font-size: 1.5rem;\n    white-space: nowrap;\n}\n\n.my_tasks:hover {\n    background-color: var(--bg-tertiary);\n    color: var(--text-primary);\n    border-color: var(--border-color);\n}\n\n/* Светлая тема — активная кнопка с затемнением как у выбранных фильтров */\n.my_tasks_active {\n    filter: brightness(0.85);\n    border-color: var(--border-color);\n}\n\n/* Тёмная тема — активная кнопка с цветным фоном */\n.wrapper.dark-theme .my_tasks_active {\n    background-color: var(--button-active-bg);\n    color: #e0e0e0;\n    border-color: var(--button-active-bg);\n    filter: none;\n}\n\n/* Переключатель темы */\n.theme_toggle_container {\n    display: flex;\n    align-items: center;\n    margin-right: 2rem;\n}\n\n.theme_toggle {\n    position: relative;\n    display: flex;\n    width: 5.4rem;\n    height: 2.8rem;\n    background-color: var(--border-color);\n    border-radius: 2.8rem;\n    cursor: pointer;\n    transition: background-color 0.3s ease;\n    border: none;\n    padding: 0;\n    align-items: center;\n    justify-content: center;\n}\n\n.theme_toggle.active {\n    background-color: var(--link-color);\n    justify-content: flex-end;\n}\n\n.theme_toggle::before {\n    content: '';\n    position: absolute;\n    width: 2.4rem;\n    height: 2.4rem;\n    border-radius: 50%;\n    transition: transform 0.3s ease;\n    margin: 0.06rem;\n    left: 0.2rem;\n    background-color: white;\n    background-image: url(${u});\n    background-repeat: no-repeat;\n    background-position: center;\n    background-size: 60%;\n}\n\n.theme_toggle.active::before {\n    transform: translateX(2.6rem);\n    background-image: url(${g});\n}\n\n/* кнопка добавления задач +++ */\n.add_task {\n    min-width: 26px;\n    min-height: 26px;\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: all 0.3s ease;\n    border: none;\n    margin: 1rem;\n    cursor: pointer;\n}\n\n.add_task * {\n    pointer-events: none;\n}\n\n.add_task:hover {\n    background-color: #8c8c8c;\n    transform: rotate(90deg);\n}\n\n.add_task:hover svg path {\n    stroke: white;\n}\n\n.add_task:active {\n    transform: scale(0.9) rotate(90deg);\n}\n\n.add_task svg {\n    width: 16px;\n    height: 16px;\n}\n\n/* кнопка добавления задач --- */\n\n/* Стили для Drag & Drop подсветки */\n.kanban-block--dragover {\n    background-color: var(--dragover-bg);\n    /* Например, светло-голубой фон */\n    /* border: 2px dashed #91d5ff; Пунктирная граница */\n    outline: 2px dashed var(--dragover-border);\n    /* Используем outline вместо border */\n    outline-offset: -2px;\n    /* Опционально: сдвигает контур внутрь, чтобы он был внутри padding */\n    transition: background-color 0.2s ease, border-color 0.2s ease;\n    /* Плавный переход */\n}\n\n/* Запрещённая зона для drop при группировке по проектам */\n.kanban-block--drop-forbidden {\n    background-color: rgba(220, 53, 69, 0.1) !important;\n    outline: 2px dashed #dc3545 !important;\n    outline-offset: -2px;\n    cursor: not-allowed;\n    position: relative;\n}\n\n/* Тёмная тема — запрещённая зона */\n.wrapper.dark-theme .kanban-block--drop-forbidden {\n    background-color: rgba(220, 53, 69, 0.15) !important;\n}\n\n/* Иконка запрета */\n.kanban-block--drop-forbidden::after {\n    content: "✕";\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    font-size: 2.4rem;\n    color: #dc3545;\n    opacity: 0.4;\n    pointer-events: none;\n}\n\n/* ========== DROPDOWN ГРУППИРОВКИ (pill-стиль как у проектов) ========== */\n.grouping_dropdown {\n    position: relative;\n    display: inline-block;\n}\n\n.grouping_toggle {\n    display: flex;\n    align-items: center;\n    padding: 0.4rem 1rem;\n    background-color: var(--button-bg);\n    border: 1px solid var(--border-color);\n    border-radius: 1.6rem;\n    cursor: pointer;\n    color: var(--text-primary);\n    font-size: 1.5rem;\n    font-family: 'Arial', sans-serif;\n    transition: all 0.3s ease;\n    -webkit-user-select: none;\n    user-select: none;\n    white-space: nowrap;\n}\n\n/* замена gap на margin для совместимости с 1С */\n.grouping_toggle > * {\n    margin-left: 0.6rem;\n}\n\n.grouping_toggle > *:first-child {\n    margin-left: 0;\n}\n\n.grouping_toggle:hover {\n    background-color: var(--bg-tertiary);\n    border-color: var(--border-color);\n}\n\n.grouping_toggle svg {\n    stroke: var(--text-secondary);\n    transition: stroke 0.3s ease;\n}\n\n.grouping_toggle .dropdown_arrow {\n    transition: transform 0.2s ease;\n}\n\n.grouping_dropdown.open .dropdown_arrow {\n    transform: rotate(180deg);\n}\n\n.grouping_menu {\n    position: absolute;\n    top: calc(100% + 0.4rem);\n    left: 0;\n    min-width: 100%;\n    background-color: var(--command-bg);\n    border: 1px solid var(--border-color);\n    border-radius: 0.8rem;\n    box-shadow: 0 4px 12px var(--card-shadow);\n    opacity: 0;\n    visibility: hidden;\n    transform: translateY(-0.5rem);\n    transition: all 0.2s ease;\n    z-index: 200;\n    overflow: hidden;\n}\n\n.grouping_dropdown.open .grouping_menu {\n    opacity: 1;\n    visibility: visible;\n    transform: translateY(0);\n}\n\n.grouping_option {\n    padding: 0.6rem 1.2rem;\n    cursor: pointer;\n    white-space: nowrap;\n    color: var(--text-primary);\n    font-size: 1.5rem;\n    transition: background-color 0.2s ease;\n    display: flex;\n    align-items: center;\n}\n\n.grouping_option:hover {\n    background-color: var(--bg-tertiary);\n}\n\n/* Светлая тема — активная опция как у my_tasks_active */\n.grouping_option.active {\n    filter: brightness(0.85);\n    background-color: var(--button-bg);\n}\n\n/* Тёмная тема — активная опция как у my_tasks_active */\n.wrapper.dark-theme .grouping_option.active {\n    background-color: var(--button-active-bg);\n    color: #e0e0e0;\n    filter: none;\n}\n\n/* галочка для активной опции */\n.grouping_option.active::after {\n    content: "✓";\n    margin-left: auto;\n    font-size: 1.2rem;\n}\n\n/* ========== EXECUTOR FILTER ========== */\n.executor_dropdown {\n    position: relative;\n    display: inline-block;\n    margin-right: 0.3rem;\n}\n\n.executor_toggle {\n    display: flex;\n    align-items: center;\n    padding: 0.4rem 1rem;\n    background-color: var(--button-bg);\n    border: 1px solid var(--border-color);\n    border-radius: 1.6rem;\n    cursor: pointer;\n    color: var(--text-primary);\n    font-size: 1.5rem;\n    font-family: 'Arial', sans-serif;\n    transition: all 0.3s ease;\n    -webkit-user-select: none;\n    user-select: none;\n    white-space: nowrap;\n}\n\n/* замена gap на margin для совместимости с 1С */\n.executor_toggle > * {\n    margin-left: 0.6rem;\n}\n\n.executor_toggle > *:first-child {\n    margin-left: 0;\n}\n\n.executor_toggle:hover {\n    background-color: var(--bg-tertiary);\n    border-color: var(--border-color);\n}\n\n.executor_toggle svg {\n    stroke: var(--text-secondary);\n    transition: stroke 0.3s ease;\n}\n\n.executor_toggle .dropdown_arrow {\n    transition: transform 0.2s ease;\n}\n\n/* Крестик очистки фильтра по исполнителям */\n.executor_clear {\n    font-size: 1.6rem;\n    opacity: 0;\n    cursor: pointer;\n    color: var(--text-secondary);\n    transition: opacity 0.2s ease;\n    line-height: 1;\n    pointer-events: none;\n    margin-left: 0.4rem;\n}\n\n/* Показывать крестик когда есть выбранные исполнители */\n.executor_dropdown.has-selected .executor_clear {\n    opacity: 0.6;\n    pointer-events: auto;\n}\n\n.executor_clear:hover {\n    opacity: 1;\n}\n\n.executor_dropdown.open .dropdown_arrow {\n    transform: rotate(180deg);\n}\n\n.executor_menu {\n    position: absolute;\n    top: calc(100% + 0.4rem);\n    left: 0;\n    min-width: 15rem;\n    max-height: 30rem;\n    overflow-y: auto;\n    background-color: var(--command-bg);\n    border: 1px solid var(--border-color);\n    border-radius: 0.8rem;\n    box-shadow: 0 4px 12px var(--card-shadow);\n    opacity: 0;\n    visibility: hidden;\n    transform: translateY(-0.5rem);\n    transition: all 0.2s ease;\n    z-index: 200;\n}\n\n.executor_dropdown.open .executor_menu {\n    opacity: 1;\n    visibility: visible;\n    transform: translateY(0);\n}\n\n.executor_option {\n    padding: 0.6rem 2.5rem 0.6rem 1.2rem;\n    cursor: pointer;\n    white-space: nowrap;\n    color: var(--text-primary);\n    font-size: 1.5rem;\n    transition: background-color 0.2s ease;\n    display: flex;\n    align-items: center;\n    position: relative;\n}\n\n.executor_option:hover {\n    background-color: var(--bg-tertiary);\n}\n\n/* Фото исполнителя в меню */\n.executor_option_photo {\n    width: 2rem;\n    height: 2.3rem;\n    border-radius: 0.3rem;\n    margin-right: 0.6rem;\n    object-fit: cover;\n    flex-shrink: 0;\n}\n\n/* Светлая тема — выбранный исполнитель */\n.executor_option.selected {\n    filter: brightness(0.85);\n    background-color: var(--button-bg);\n}\n\n/* Тёмная тема — выбранный исполнитель */\n.wrapper.dark-theme .executor_option.selected {\n    background-color: var(--button-active-bg);\n    color: #e0e0e0;\n    filter: none;\n}\n\n/* галочка для выбранного исполнителя */\n.executor_option.selected::after {\n    content: "✓";\n    position: absolute;\n    right: 1rem;\n    font-size: 1.2rem;\n}\n\n/* ========== URGENCY FILTER ========== */\n.urgency_dropdown {\n    position: relative;\n    display: inline-block;\n    margin-right: 0.3rem;\n}\n\n.urgency_toggle {\n    display: flex;\n    align-items: center;\n    padding: 0.4rem 1rem;\n    background-color: var(--button-bg);\n    border: 1px solid var(--border-color);\n    border-radius: 1.6rem;\n    cursor: pointer;\n    color: var(--text-primary);\n    font-size: 1.5rem;\n    font-family: 'Arial', sans-serif;\n    transition: all 0.3s ease;\n    -webkit-user-select: none;\n    user-select: none;\n    white-space: nowrap;\n}\n\n.urgency_toggle > * {\n    margin-left: 0.6rem;\n}\n\n.urgency_toggle > *:first-child {\n    margin-left: 0;\n}\n\n.urgency_toggle:hover {\n    background-color: var(--bg-tertiary);\n}\n\n.urgency_clear {\n    font-size: 1.6rem;\n    opacity: 0;\n    cursor: pointer;\n    color: var(--text-secondary);\n    transition: opacity 0.2s ease;\n    pointer-events: none;\n    margin-left: 0.4rem;\n}\n\n.urgency_dropdown.has-selected .urgency_clear {\n    opacity: 0.6;\n    pointer-events: auto;\n}\n\n.urgency_dropdown.open .urgency_menu {\n    opacity: 1;\n    visibility: visible;\n    transform: translateY(0);\n}\n\n.urgency_menu {\n    position: absolute;\n    top: calc(100% + 0.4rem);\n    left: 0;\n    min-width: 14rem;\n    max-height: 28rem;\n    overflow-y: auto;\n    background-color: var(--command-bg);\n    border: 1px solid var(--border-color);\n    border-radius: 0.8rem;\n    box-shadow: 0 4px 12px var(--card-shadow);\n    opacity: 0;\n    visibility: hidden;\n    transform: translateY(-0.5rem);\n    transition: all 0.2s ease;\n    z-index: 200;\n}\n\n.urgency_option {\n    display: flex;\n    align-items: center;\n    padding: 0.6rem 2.5rem 0.6rem 1.2rem;\n    cursor: pointer;\n    white-space: nowrap;\n    color: var(--text-primary);\n    font-size: 1.5rem;\n    transition: background-color 0.2s ease;\n    position: relative;\n}\n\n.urgency_option_label {\n    flex: 1;\n    min-width: 0;\n}\n\n.urgency_option_settings {\n    flex-shrink: 0;\n    width: 2.2rem;\n    height: 2.2rem;\n    margin-left: 0.4rem;\n    padding: 0;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    background: transparent;\n    border: none;\n    border-radius: 0.4rem;\n    cursor: pointer;\n    color: var(--text-secondary);\n    transition: background 0.2s, color 0.2s;\n}\n\n.urgency_option_settings:hover {\n    background: var(--bg-tertiary);\n    color: var(--text-primary);\n}\n\n.urgency_option_settings svg {\n    pointer-events: none;\n}\n\n.urgency_option:hover {\n    background-color: var(--bg-tertiary);\n}\n\n.urgency_option.selected::after {\n    content: "✓";\n    position: absolute;\n    right: 1rem;\n    font-size: 1.2rem;\n}\n\n/* ========== CARD TYPE FILTER (Тип: Задача / Ошибка) ========== */\n.cardtype_dropdown {\n    position: relative;\n    display: inline-block;\n    margin-right: 0.3rem;\n}\n\n.cardtype_toggle {\n    display: flex;\n    align-items: center;\n    padding: 0.4rem 1rem;\n    background-color: var(--button-bg);\n    border: 1px solid var(--border-color);\n    border-radius: 1.6rem;\n    cursor: pointer;\n    color: var(--text-primary);\n    font-size: 1.5rem;\n    font-family: 'Arial', sans-serif;\n    transition: all 0.3s ease;\n    -webkit-user-select: none;\n    user-select: none;\n    white-space: nowrap;\n}\n\n.cardtype_toggle > * {\n    margin-left: 0.6rem;\n}\n\n.cardtype_toggle > *:first-child {\n    margin-left: 0;\n}\n\n.cardtype_toggle:hover {\n    background-color: var(--bg-tertiary);\n}\n\n.cardtype_clear {\n    font-size: 1.6rem;\n    opacity: 0;\n    cursor: pointer;\n    color: var(--text-secondary);\n    transition: opacity 0.2s ease;\n    pointer-events: none;\n    margin-left: 0.4rem;\n}\n\n.cardtype_dropdown.has-selected .cardtype_clear {\n    opacity: 0.6;\n    pointer-events: auto;\n}\n\n.cardtype_dropdown.open .cardtype_menu {\n    opacity: 1;\n    visibility: visible;\n    transform: translateY(0);\n}\n\n.cardtype_menu {\n    position: absolute;\n    top: calc(100% + 0.4rem);\n    left: 0;\n    min-width: 12rem;\n    max-height: 28rem;\n    overflow-y: auto;\n    background-color: var(--command-bg);\n    border: 1px solid var(--border-color);\n    border-radius: 0.8rem;\n    box-shadow: 0 4px 12px var(--card-shadow);\n    opacity: 0;\n    visibility: hidden;\n    transform: translateY(-0.5rem);\n    transition: all 0.2s ease;\n    z-index: 200;\n}\n\n.cardtype_option {\n    display: flex;\n    align-items: center;\n    padding: 0.6rem 2.5rem 0.6rem 1.2rem;\n    cursor: pointer;\n    white-space: nowrap;\n    color: var(--text-primary);\n    font-size: 1.5rem;\n    transition: background-color 0.2s ease;\n    position: relative;\n}\n\n.cardtype_option:hover {\n    background-color: var(--bg-tertiary);\n}\n\n.cardtype_option.selected::after {\n    content: "✓";\n    position: absolute;\n    right: 1rem;\n    font-size: 1.2rem;\n}\n\n/* ========== SETTINGS MODAL (срочность) ========== */\n.settings_modal {\n    position: fixed;\n    inset: 0;\n    z-index: 1000;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    opacity: 0;\n    visibility: hidden;\n    transition: opacity 0.2s ease, visibility 0.2s ease;\n}\n\n.settings_modal.open {\n    opacity: 1;\n    visibility: visible;\n}\n\n.settings_modal_backdrop {\n    position: absolute;\n    inset: 0;\n    background-color: rgba(0, 0, 0, 0.4);\n}\n\n.settings_modal_content {\n    position: relative;\n    background-color: var(--command-bg);\n    border: 1px solid var(--border-color);\n    border-radius: 1rem;\n    padding: 2rem;\n    max-width: 36rem;\n    width: 90%;\n    max-height: 90vh;\n    overflow-y: auto;\n    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);\n}\n\n.settings_modal_title {\n    margin: 0 0 0.5rem 0;\n    font-size: 1.8rem;\n    color: var(--text-primary);\n}\n\n.settings_modal_hint {\n    margin: 0 0 1.5rem 0;\n    font-size: 1.3rem;\n    color: var(--text-secondary);\n}\n\n.urgency_settings_list {\n    margin-bottom: 1.5rem;\n}\n\n.urgency_settings_empty {\n    color: var(--text-secondary);\n    font-size: 1.4rem;\n    margin: 0;\n}\n\n.urgency_setting_row {\n    display: flex;\n    flex-wrap: wrap;\n    align-items: center;\n    gap: 0.8rem;\n    margin-bottom: 1.2rem;\n    padding-bottom: 1rem;\n    border-bottom: 1px solid var(--border-color);\n}\n\n.urgency_setting_row:last-child {\n    border-bottom: none;\n    margin-bottom: 0;\n    padding-bottom: 0;\n}\n\n.urgency_setting_label {\n    flex: 0 0 100%;\n    font-size: 1.4rem;\n    font-weight: 600;\n    color: var(--text-primary);\n    margin-bottom: 0.2rem;\n}\n\n.urgency_setting_icons,\n.urgency_setting_colors {\n    display: flex;\n    gap: 0.4rem;\n    align-items: center;\n}\n\n.urgency_icon_btn {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 2.4rem;\n    height: 2.4rem;\n    padding: 0;\n    border: 1px solid var(--border-color);\n    border-radius: 0.4rem;\n    background: var(--button-bg);\n    cursor: pointer;\n    color: var(--text-secondary);\n    transition: background 0.2s, color 0.2s;\n}\n\n.urgency_icon_btn:hover {\n    background: var(--bg-tertiary);\n    color: var(--text-primary);\n}\n\n.urgency_icon_btn.selected {\n    border-color: var(--link-color);\n    color: var(--link-color);\n    background: var(--bg-tertiary);\n}\n\n.urgency_icon_btn .urgency-icon-svg {\n    width: 1.6rem;\n    height: 1.6rem;\n    fill: currentColor;\n}\n\n.urgency_color_btn {\n    width: 2rem;\n    height: 2rem;\n    border-radius: 50%;\n    border: 2px solid transparent;\n    padding: 0;\n    cursor: pointer;\n    transition: transform 0.2s, border-color 0.2s;\n}\n\n.urgency_color_btn:hover {\n    transform: scale(1.1);\n}\n\n.urgency_color_btn.selected {\n    border-color: var(--text-primary);\n    box-shadow: 0 0 0 1px var(--border-color);\n}\n\n.settings_modal_actions {\n    margin-top: 1rem;\n}\n\n.settings_modal_close {\n    padding: 0.5rem 1.2rem;\n    background-color: var(--button-bg);\n    border: 1px solid var(--border-color);\n    border-radius: 0.8rem;\n    cursor: pointer;\n    font-size: 1.4rem;\n    color: var(--text-primary);\n    transition: background 0.2s;\n}\n\n.settings_modal_close:hover {\n    background-color: var(--bg-tertiary);\n}\n\n/* ========== SEARCH ========== */\n.search_container {\n    position: relative;\n    display: flex;\n    align-items: center;\n    margin-left: 1rem;\n}\n\n.search_input {\n    padding: 0.4rem 2.5rem 0.4rem 1rem;\n    background-color: var(--button-bg);\n    border: 1px solid var(--border-color);\n    border-radius: 1.6rem;\n    color: var(--text-primary);\n    font-size: 1.5rem;\n    font-family: 'Arial', sans-serif;\n    outline: none;\n    min-width: 15rem;\n    transition: border-color 0.2s ease;\n}\n\n.search_input::placeholder {\n    color: var(--text-secondary);\n}\n\n.search_input:focus {\n    border-color: var(--link-color);\n}\n\n/* Крестик очистки поиска */\n.search_clear {\n    position: absolute;\n    right: 1rem;\n    font-size: 1.6rem;\n    opacity: 0;\n    cursor: pointer;\n    color: var(--text-secondary);\n    transition: opacity 0.2s ease;\n    line-height: 1;\n    pointer-events: none;\n}\n\n/* Показывать крестик когда есть текст */\n.search_container.has-text .search_clear {\n    opacity: 0.6;\n    pointer-events: auto;\n}\n\n.search_clear:hover {\n    opacity: 1;\n}\n\n/* Скрытие карточек при поиске */\n.card.card__search_hidden {\n    display: none;\n}\n\n/* Скрытие карточек при переполнении колонки */\n.card.card__overflow_hidden {\n    display: none;\n}\n\n.show_all_link {\n    display: block;\n    text-align: center;\n    color: var(--text-secondary);\n    cursor: pointer;\n    padding: 0.6rem 1rem;\n    margin: 0.8rem 0.6rem 0;\n    font-size: 1.3rem;\n    font-style: italic;\n    border: 1px dashed var(--border-color);\n    border-radius: 0.6rem;\n    background-color: transparent;\n    -webkit-user-select: none;\n    user-select: none;\n    transition: background-color 0.2s ease, color 0.2s ease;\n}\n\n.show_all_link:hover {\n    background-color: var(--bg-tertiary);\n    color: var(--text-primary);\n}\n\n/* ========== ГРУППЫ (SWIMLANES) ========== */\n.group {\n    width: 100%;\n}\n\n/* Первая группа - отступ сверху для sticky заголовка */\n.group:first-child {\n    margin-top: 12.8rem;\n}\n\n.group-header {\n    display: flex;\n    align-items: center;\n    \n    padding: 1rem 1.2rem;\n    background-color: var(--bg-secondary);\n    border-bottom: 1px solid var(--border-color);\n    cursor: pointer;\n    user-select: none;\n    transition: background-color 0.2s ease;\n    margin-top: 0.5rem;\n}\n\n.group-header > * {\n    margin-right: 2rem;\n}\n\n.group-header:hover {\n    background-color: var(--header-hover);\n}\n\n.group-toggle {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 2rem;\n    height: 2rem;\n    transition: transform 0.2s ease;\n}\n\n.group-toggle svg {\n    stroke: var(--text-secondary);\n    transition: stroke 0.2s ease;\n}\n\n.group.collapsed .group-toggle {\n    transform: rotate(-90deg);\n}\n\n/* Фото исполнителя в заголовке группы */\n.group-photo {\n    width: 3.5rem;\n    height: 4rem;\n    border: 1px solid var(--border-color);\n    background-color: var(--bg-secondary);\n    border-radius: 0.3rem;\n    object-fit: cover;\n    transition: background-color 0.3s ease;\n}\n\n.group-project-color {\n    width: 1.2rem;\n    height: 1.2rem;\n    border-radius: 50%;\n    margin-right: 0.8rem;\n    flex-shrink: 0;\n}\n\n.group-name {\n    font-weight: 500;\n    color: var(--text-primary);\n    font-size: 1.5rem;\n}\n\n.group-count {\n    color: var(--text-tertiary);\n    font-weight: bold;\n}\n\n/* Фото в карточках НЕ скрываем при группировке */\n\n.group-content {\n    display: flex;\n    width: 100%;\n}\n\n.group.collapsed .group-content {\n    display: none;\n}\n\n/* Блоки внутри группы */\n.group-content .kanban-block {\n    margin-top: 0;\n    min-height: 8rem;\n    border-radius: 0;\n    border-left: 1px solid var(--border-color);\n}\n\n.group-content .kanban-block:first-child {\n    border-left: none;\n}\n\n/* Когда группировка активна, убираем отступ сверху у обычных блоков */\n#kanban-board.grouped .kanban-block {\n    margin-top: 0;\n}\n\n/* Режим без группировки */\n#kanban-board:not(.grouped) {\n    display: flex;\n    flex-direction: row;\n}\n\n#kanban-board:not(.grouped) .kanban-block {\n    margin-top: 11.8rem;\n    min-height: calc(100vh - 11.8rem);\n}\n\n/* Режим с группировкой */\n#kanban-board.grouped {\n    display: flex;\n    flex-direction: column;\n}\n\n@media only screen and (max-width: 1450px) {\n    body {\n        font-size: 1.5rem;\n    }\n\n    .card__photo {\n        width: 2.5rem;\n        height: 3rem;\n    }\n}\n\n@media 