// @strict-types

#Область СлужебныйПрограммныйИнтерфейс

// Фиксирует открытие канбан-доски в Яндекс.Метрике (Measurement Protocol).
// Ошибки сети не прерывают работу формы.
//
Процедура ЗафиксироватьОткрытиеДоски() Экспорт
	
	ОтправитьХитОткрытияДоски();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОтправитьХитОткрытияДоски()
	
	ИдентификаторИБ = СтандартныеПодсистемыСервер.ИдентификаторИнформационнойБазы();
	
	ТекущийПользователь = Пользователи.ТекущийПользователь();
	Если Не ЗначениеЗаполнено(ТекущийПользователь) Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторПользователя = Строка(ТекущийПользователь.УникальныйИдентификатор());
	ClientID = ClientIDМетрики(ИдентификаторИБ, ИдентификаторПользователя);
	
	АдресСтраницы = "https://github.com/ViktorErmakov/";
	АдресСтраницыКодированный = КодироватьСтроку(АдресСтраницы, СпособКодированияСтроки.КодировкаURL);
	
	АдресРесурса = СтрШаблон(
		"/collect/?tid=110197747&ms=9cb35914-32d4-491f-86cb-099a95df7704&t=pageview&cid=%1&dr=%2&dl=%3",
		ClientID,
		АдресСтраницыКодированный,
		АдресСтраницыКодированный);
	
	Попытка
		
		ТаймаутСекунды = 5;
		ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL;
		Соединение = Новый HTTPСоединение("mc.yandex.ru", 443, , , , ТаймаутСекунды, ЗащищенноеСоединение);
		Запрос = Новый HTTPЗапрос(АдресРесурса);
		ОтправитьHTTPЗапросМетрики(Соединение, Запрос);
		
	Исключение
		
		// Ошибки сети не должны прерывать открытие доски.
		Возврат;
		
	КонецПопытки;
	
КонецПроцедуры

// Отправить HTTPЗапрос метрики.
// 
// Параметры:
//  Соединение - HTTPСоединение - Соединение
//  Запрос - HTTPЗапрос - Запрос
//
Процедура ОтправитьHTTPЗапросМетрики(Знач Соединение, Знач Запрос)
	
	// OneSniffer: перехват и запись исходящего HTTP в логи (если расширение подключено).
	//@skip-warning
	Если ОбщегоНазначения.ПодсистемаСуществует("OneSniffer") Тогда
		
		//@skip-warning
		Модуль_HTTPСоединение = ОбщегоНазначения.ОбщийМодуль("_HTTPСоединение");
		//@skip-warning
		Модуль_HTTPСоединение._ВызватьHTTPМетод(Соединение, "GET", Запрос, , "OneKanban.YandexMetrika");
		
	Иначе
		
		Соединение.ВызватьHTTPМетод("GET", Запрос);
		
	КонецЕсли;
	
КонецПроцедуры

// Client IDМетрики.
// 
// Параметры:
//  ИдентификаторИБ - Строка - Идентификатор ИБ
//  ИдентификаторПользователя - Строка - Идентификатор пользователя
// 
// Возвращаемое значение:
//  Строка
//
Функция ClientIDМетрики(Знач ИдентификаторИБ, Знач ИдентификаторПользователя)
	
	// Метрика принимает cid длиной до 19 цифр (как в примерах API): 10 из ИБ + 9 из пользователя.
	ЦифрыИБ = ЦифрыИдентификатора(Строка(ИдентификаторИБ), 10);
	ЦифрыПользователя = ЦифрыИдентификатора(ИдентификаторПользователя, 9);
	
	Возврат ЦифрыИБ + ЦифрыПользователя;
	
КонецФункции

// Цифры идентификатора.
// 
// Параметры:
//  Идентификатор - Строка - Идентификатор
//  Длина - Число - Длина
// 
// Возвращаемое значение:
//  Строка
//
Функция ЦифрыИдентификатора(Идентификатор, Длина)
	
	Цифры = "";
	
	Для Индекс = 1 По СтрДлина(Идентификатор) Цикл
		
		Символ = Сред(Идентификатор, Индекс, 1);
		
		Если Символ >= "0" И Символ <= "9" Тогда
			Цифры = Цифры + Символ;
		КонецЕсли;
		
		Если СтрДлина(Цифры) >= Длина Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Пока СтрДлина(Цифры) < Длина Цикл
		Цифры = "0" + Цифры;
	КонецЦикла;
	
	Возврат Цифры;
	
КонецФункции

#КонецОбласти
