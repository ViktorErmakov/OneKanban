// @strict-types

#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

#Область ДляВызоваИзДругихПодсистем

// СтандартныеПодсистемы.ВариантыОтчетов
//
// Параметры:
//  Настройки - см. ВариантыОтчетовПереопределяемый.НастроитьВариантыОтчетов.Настройки.
//  НастройкиОтчета - см. ВариантыОтчетов.ОписаниеОтчета.
//
Процедура НастроитьВариантыОтчета(Настройки, НастройкиОтчета) Экспорт
	
	Если Не ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.ВариантыОтчетов") Тогда
		Возврат;
	КонецЕсли;
	
	МодульВариантыОтчетов = ОбщегоНазначения.ОбщийМодуль("ВариантыОтчетов");
	//@skip-check property-return-type
	НастройкиОтчета.Включен = Истина;
	//@skip-check property-return-type
	НастройкиОтчета.ОпределитьНастройкиФормы = Истина;
	//@skip-check property-return-type
	НастройкиОтчета.Описание = НСтр("ru = 'История нахождения задач в статусах: интервалы и длительность.'");
	НастройкиОтчета.Размещение.Вставить(Метаданные.Подсистемы.канбан_ДоскаИнтерфейс, "История задач");
	
	ОписатьВариантОтчетаИсторияЗадач(МодульВариантыОтчетов, Настройки, НастройкиОтчета,
		"Детально", НСтр("ru = 'Поэтапная история статусов задач.'"));
	ОписатьВариантОтчетаИсторияЗадач(МодульВариантыОтчетов, Настройки, НастройкиОтчета,
		"СводкаПоЗадаче", НСтр("ru = 'Суммарное время в статусах по задаче.'"));
	ОписатьВариантОтчетаИсторияЗадач(МодульВариантыОтчетов, Настройки, НастройкиОтчета,
		"СводкаПоСтатусу", НСтр("ru = 'Суммарное время в каждом статусе.'"));
	ОписатьВариантОтчетаИсторияЗадач(МодульВариантыОтчетов, Настройки, НастройкиОтчета,
		"СводкаПоИсполнителю", НСтр("ru = 'Суммарное время по исполнителям и статусам.'"));
	ОписатьВариантОтчетаИсторияЗадач(МодульВариантыОтчетов, Настройки, НастройкиОтчета,
		"СводкаПоПроекту", НСтр("ru = 'Суммарное время по проектам и статусам.'"));
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.ВариантыОтчетов

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОписатьВариантОтчетаИсторияЗадач(МодульВариантыОтчетов, Настройки, НастройкиОтчета, ИмяВарианта, Описание)
	
	НастройкиВарианта = МодульВариантыОтчетов.ОписаниеВарианта(Настройки, НастройкиОтчета, ИмяВарианта);
	//@skip-check property-return-type
	НастройкиВарианта.Описание = Описание;
	НастройкиВарианта.Включен = Истина;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли
