// @strict-types

#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// СтандартныеПодсистемы.ВариантыОтчетов
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма отчёта.
//  КлючВарианта - Строка - ключ варианта отчёта.
//  Настройки - Структура - настройки событий формы отчёта.
//
Процедура ОпределитьНастройкиФормы(Форма, КлючВарианта, Настройки) Экспорт
	
	//@skip-check property-return-type
	Настройки.События.ПриСозданииНаСервере = Истина;
	
КонецПроцедуры

// СтандартныеПодсистемы.ВариантыОтчетов
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма отчёта.
//  Отказ - Булево
//  СтандартнаяОбработка - Булево
//
Процедура ПриСозданииНаСервере(Форма, Отказ, СтандартнаяОбработка) Экспорт
	
	Если канбан_КанбанДоска.ИспользуетсяВедениеОшибок() Тогда
		Возврат;
	КонецЕсли;
	
	СкрытьПараметрОтчета(Форма, "СтатусОшибки");
	ОтключитьПараметрНастроекОтчета(Форма, "СтатусОшибки");
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.ВариантыОтчетов

#КонецОбласти

#Область ОбработчикиСобытий

// Подстановка текста запроса из переопределяемого модуля (ветка по конфигурации).
//
Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
	
	СхемаКомпоновкиДанных = ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	НаборДанных = СхемаКомпоновкиДанных.НаборыДанных.Найти("ОсновнойНабор");
	
	Если НаборДанных <> Неопределено Тогда
		НаборДанных.Запрос = канбан_КанбанДоскаПереопределяемый.ТекстЗапросаОтчетаИсторияЗадач();
	КонецЕсли;
	
	Настройки = КомпоновщикНастроек.ПолучитьНастройки();
	УстановитьПараметрыВключенияВетокЗапроса(Настройки);
	
	КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаКомпоновкиДанных));
	КомпоновщикНастроек.ЗагрузитьНастройки(Настройки);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура УстановитьПараметрыВключенияВетокЗапроса(Настройки)
	
	ИспользуетсяСтатусЗадачи = ПараметрСКДИспользуется(Настройки, "Статус");
	ИспользуетсяСтатусОшибки = ПараметрСКДИспользуется(Настройки, "СтатусОшибки");
	
	Если Не канбан_КанбанДоска.ИспользуетсяВедениеОшибок() Тогда
		ИспользуетсяСтатусОшибки = Ложь;
		ОтключитьПараметрНастроек(Настройки, "СтатусОшибки");
	КонецЕсли;
	
	ВключатьЗадачи = Не ИспользуетсяСтатусОшибки Или ИспользуетсяСтатусЗадачи;
	ВключатьОшибки = канбан_КанбанДоска.ИспользуетсяВедениеОшибок()
		И (Не ИспользуетсяСтатусЗадачи Или ИспользуетсяСтатусОшибки);
	
	УстановитьЗначениеПараметраНастроек(Настройки, "ВключатьЗадачи", ВключатьЗадачи);
	УстановитьЗначениеПараметраНастроек(Настройки, "ВключатьОшибки", ВключатьОшибки);
	
КонецПроцедуры

Функция ПараметрСКДИспользуется(Настройки, ИмяПараметра)
	
	ЭлементПараметра = НайтиПараметрНастроек(Настройки, ИмяПараметра);
	
	Если ЭлементПараметра = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат ЭлементПараметра.Использование;
	
КонецФункции

Функция НайтиПараметрНастроек(Настройки, ИмяПараметра)
	
	ПараметрКомпоновки = Новый ПараметрКомпоновкиДанных(ИмяПараметра);
	
	Для Каждого ЭлементПараметра Из Настройки.ПараметрыДанных.Элементы Цикл
		
		Если ЭлементПараметра.Параметр = ПараметрКомпоновки Тогда
			Возврат ЭлементПараметра;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

Процедура УстановитьЗначениеПараметраНастроек(Настройки, ИмяПараметра, Значение)
	
	ЭлементПараметра = НайтиПараметрНастроек(Настройки, ИмяПараметра);
	
	Если ЭлементПараметра = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЭлементПараметра.Значение = Значение;
	ЭлементПараметра.Использование = Истина;
	
КонецПроцедуры

Процедура ОтключитьПараметрНастроек(Настройки, ИмяПараметра)
	
	ЭлементПараметра = НайтиПараметрНастроек(Настройки, ИмяПараметра);
	
	Если ЭлементПараметра <> Неопределено Тогда
		ЭлементПараметра.Использование = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОтключитьПараметрНастроекОтчета(Форма, ИмяПараметра)
	
	КомпоновщикНастроек = КомпоновщикНастроекФормыОтчета(Форма);
	
	Если КомпоновщикНастроек = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Настройки = КомпоновщикНастроек.ПолучитьНастройки();
	ОтключитьПараметрНастроек(Настройки, ИмяПараметра);
	КомпоновщикНастроек.ЗагрузитьНастройки(Настройки);
	
КонецПроцедуры

Процедура СкрытьПараметрОтчета(Форма, ИмяПараметра)
	
	КомпоновщикНастроек = КомпоновщикНастроекФормыОтчета(Форма);
	
	Если КомпоновщикНастроек = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрКомпоновки = Новый ПараметрКомпоновкиДанных(ИмяПараметра);
	
	Для Каждого ДоступныйПараметр Из КомпоновщикНастроек.Настройки.ДоступныеПараметры.Элементы Цикл
		
		Если ДоступныйПараметр.Параметр = ПараметрКомпоновки Тогда
			ДоступныйПараметр.ВключатьВДоступныеПоля = Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	СкрытьЭлементыФормыПараметра(Форма, ИмяПараметра);
	
КонецПроцедуры

Процедура СкрытьЭлементыФормыПараметра(Форма, ИмяПараметра)
	
	СкрытьЭлементыФормыПоИмени(Форма.Элементы, ИмяПараметра);
	
КонецПроцедуры

Процедура СкрытьЭлементыФормыПоИмени(ЭлементыФормы, ИмяПараметра)
	
	Для Каждого ЭлементФормы Из ЭлементыФормы Цикл
		
		Если СтрНайти(ВРег(ЭлементФормы.Имя), ВРег(ИмяПараметра)) > 0 Тогда
			ЭлементФормы.Видимость = Ложь;
		КонецЕсли;
		
		Если ТипЗнч(ЭлементФормы) = Тип("ГруппаФормы") Тогда
			СкрытьЭлементыФормыПоИмени(ЭлементФормы.ПодчиненныеЭлементы, ИмяПараметра);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция КомпоновщикНастроекФормыОтчета(Форма)
	
	Если Не ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.ВариантыОтчетов") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	МодульОтчетыКлиентСервер = ОбщегоНазначения.ОбщийМодуль("ОтчетыКлиентСервер");
	//@skip-check dynamic-access-method-not-found
	Возврат МодульОтчетыКлиентСервер.КомпоновщикНастроекОтчета(Форма);
	
КонецФункции

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'");
#КонецЕсли
